api.leasesights.tech {
    # CORS headers at proxy level — handles all browsers
    header {
        Access-Control-Allow-Origin "https://www.leasesights.tech"
        Access-Control-Allow-Methods "GET, POST, OPTIONS, PUT, DELETE"
        Access-Control-Allow-Headers "Content-Type, Authorization, X-OpenAI-Key, X-Pinecone-Key"
        Access-Control-Expose-Headers "*"
        Access-Control-Allow-Credentials "true"
    }

    # Handle preflight OPTIONS directly at proxy
    @options {
        method OPTIONS
    }
    respond @options 204

    # Reverse proxy to backend container
    reverse_proxy localhost:8080
}

www.leasesights.tech {
    root * /var/www/leasesight-ui
    file_server

    # SPA routing: serve index.html for non-file routes
    try_files {path} /index.html
}

# Development (local machine)
localhost:3000 {
    file_server {
        root /path/to/leasesight-ui/dist
    }
    try_files {path} /index.html
}

localhost:8000 {
    header {
        Access-Control-Allow-Origin "*"
        Access-Control-Allow-Methods "GET, POST, OPTIONS, PUT, DELETE"
        Access-Control-Allow-Headers "*"
    }
    reverse_proxy localhost:8080
}
