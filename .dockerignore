# .dockerignore - Speed up builds while preserving essential data
venv/
.venv/
__pycache__/
*.pyc
.git/

# Allow data folder to be copied so existing PDFs are available
# data/  <-- REMOVED from ignore to solve "not taking files" issue

# Skip UI folder (it's a separate build/service)
leasesight-ui/

# Skip logs
*.log
